  "description": "Ritmo is a generative graphics studio with four p5.js workspaces — Ritmo, Borro, Copo and Refrac — sharing the Grafema architecture and design system.",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-html": "^8.1.4",
    "globals": "^17.6.0",
    "lightningcss": "^1.32.0",
    "p5": "^1.11.13",
    "prettier": "^3.8.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8",
    "workbox-window": "^7.4.1"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "lint": "eslint src --max-warnings 0",
    "format": "prettier --write \"src/**/*.{js,css,html}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/legenki/ritmo.git"
